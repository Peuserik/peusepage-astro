---
import MonitorBezel from '../components/MonitorBezel.astro';
import Controls from '../components/Controls.svelte';
import LandingCanvas from '../components/LandingCanvas.svelte';
import { config, translations } from '../lib/config';
import '../styles/global.css';

const officeUrl = `${import.meta.env.BASE_URL}office`;
---

<!doctype html>
<html lang="en" data-theme="warm" data-mode="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{config.person.name} — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Space+Grotesk:wght@700&family=Bebas+Neue&family=Cinzel:wght@700&family=Special+Elite&family=Major+Mono+Display&family=VT323&display=swap" rel="stylesheet" />
  <script>
    // Restore persisted settings before first paint (handles both JSON and plain strings)
    (function(){
      const h = document.documentElement;
      function safe(key, fallback) {
        try { const v = localStorage.getItem(key); return v !== null ? JSON.parse(v) : fallback; }
        catch { return localStorage.getItem(key) ?? fallback; }
      }
      const dark = safe('psp_dark', true);
      const th   = safe('psp_theme', 'warm');
      const l    = safe('psp_lang', 'en');
      h.setAttribute('data-mode',  dark ? 'dark' : 'light');
      h.setAttribute('data-theme', th);
      h.setAttribute('lang', l);
    })();
  </script>
</head>
<body>
  <MonitorBezel>
    <!-- LandingCanvas owns the Pixi scene + certificate + welcome text + hint -->
    <LandingCanvas
      client:only="svelte"
      name={config.person.name}
      title={config.person.title}
      tagline={config.person.tagline}
      officeUrl={officeUrl}
      translationsJson={JSON.stringify(translations)}
    />
    <!-- Controls live in the bezel (named slot) -->
    <Controls client:only="svelte" slot="controls" />
  </MonitorBezel>

  <style>
    body { margin: 0; overflow: hidden; background: var(--bg, #1a1008); }
  </style>
</body>
</html>
